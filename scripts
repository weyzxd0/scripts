-- ===== FPS COUNTER =====
local lastUpdate = tick()
local frames = 0
connections.fpsCounter = run.RenderStepped:Connect(function()
    frames = frames + 1
    if tick() - lastUpdate >= 1 then
        local fps = frames
        fpsLabel.Text = "FPS: " .. fps
        if fps >= 60 then fpsLabel.TextColor3 = COLORS.Success
        elseif fps >= 30 then fpsLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
        else fpsLabel.TextColor3 = COLORS.Error end
        frames = 0
        lastUpdate = tick()
    end
end)

