-- AUTO PLATFORM
local maxHeightReached = 0
local isJumping = false
local lastVelocityY = 0
local platformDebounce = false

connections.autoPlatformBuilder = run.Heartbeat:Connect(function()
    if not CONFIG.PlatformBuilderAuto then
        isJumping = false
        maxHeightReached = 0
        lastVelocityY = 0
        return
    end
    local char = plr.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if not hrp or not hum then return end
    
    local currentHeight = hrp.Position.Y
    local currentVelocityY = hrp.AssemblyLinearVelocity.Y
    local state = hum:GetState()
    
    if state == Enum.HumanoidStateType.Jumping and not isJumping then
        isJumping = true
        maxHeightReached = currentHeight
        platformDebounce = false
    end
    
    if isJumping and (state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall) then
        if currentHeight > maxHeightReached then maxHeightReached = currentHeight end
        if lastVelocityY > 0 and currentVelocityY <= 0 and not platformDebounce then
            platformDebounce = true
            local platformPos = Vector3.new(hrp.Position.X, maxHeightReached - CONFIG.PlatformHeight - 3, hrp.Position.Z)
            local platform = Instance.new("Part", workspace)
            platform.Name = "Hulk_Platform_Auto"
            platform.Size = Vector3.new(6, 0.5, 6)
            platform.Position = platformPos
            platform.Anchored = true
            platform.CanCollide = true
            platform.Material = Enum.Material.Neon
            platform.Color = COLORS.Primary
            platform.Transparency = 0.3
            local mesh = Instance.new("SpecialMesh", platform)
            mesh.MeshType = Enum.MeshType.Brick
            mesh.Scale = Vector3.new(1, 0.8, 1)
            local decal = Instance.new("Decal", platform)
            decal.Face = Enum.NormalId.Top
            decal.Texture = "rbxassetid://92258030640998"
            local light = Instance.new("PointLight", platform)
            light.Color = COLORS.Primary
            light.Brightness = 2
            light.Range = 15
            spawn(function()
                wait(60)
                if platform and platform.Parent then
                    tween(platform, {Transparency = 1, Size = Vector3.new(0, 0.5, 0)}, 0.5)
                    wait(0.5)
                    platform:Destroy()
                end
            end)
        end
    end
    if state == Enum.HumanoidStateType.Landed or state == Enum.HumanoidStateType.Running then
        if isJumping then isJumping = false maxHeightReached = 0 end
    end
    lastVelocityY = currentVelocityY
end)

