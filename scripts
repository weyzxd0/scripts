-- Ice Block Functions
local function clearIceBlock(targetPlayer)
    pcall(function()
        if iceUpdateConnections[targetPlayer] then iceUpdateConnections[targetPlayer]:Disconnect() iceUpdateConnections[targetPlayer] = nil end
        if iceBlockCache[targetPlayer] then
            for _, obj in pairs(iceBlockCache[targetPlayer]) do pcall(function() obj:Destroy() end) end
            iceBlockCache[targetPlayer] = nil
        end
        frozenPositions[targetPlayer] = nil
    end)
end

local function createIceBlock(targetPlayer)
    if targetPlayer == plr then return end
    if not CONFIG.IceBlockEnabled then return end
    task.spawn(function()
        pcall(function()
            local char = targetPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            clearIceBlock(targetPlayer)
            iceBlockCache[targetPlayer] = {}
            local frozenPos = hrp.Position
            frozenPositions[targetPlayer] = frozenPos
            local width, height, depth, thickness = 6, 8, 6, 0.3
            
            -- Ice Container
            local iceContainer = Instance.new("Part")
            iceContainer.Name = "IceContainer_" .. targetPlayer.Name
            iceContainer.Size = Vector3.new(0.1, 0.1, 0.1)
            iceContainer.Position = frozenPos
            iceContainer.Anchored = true
            iceContainer.CanCollide = false
            iceContainer.Transparency = 1
            iceContainer.Parent = workspace
            table.insert(iceBlockCache[targetPlayer], iceContainer)
            
            -- Ice Walls
            local walls = {
                {size = Vector3.new(width, height, thickness), offset = Vector3.new(0, 0, depth/2)},
                {size = Vector3.new(width, height, thickness), offset = Vector3.new(0, 0, -depth/2)},
                {size = Vector3.new(thickness, height, depth), offset = Vector3.new(-width/2, 0, 0)},
                {size = Vector3.new(thickness, height, depth), offset = Vector3.new(width/2, 0, 0)},
                {size = Vector3.new(width, thickness, depth), offset = Vector3.new(0, height/2, 0)},
                {size = Vector3.new(width, thickness, depth), offset = Vector3.new(0, -height/2, 0)},
            }
            for i, wallData in ipairs(walls) do
                local wall = Instance.new("Part")
                wall.Name = "IceWall_" .. i
                wall.Size = wallData.size
                wall.Anchored = true
                wall.CanCollide = false
                wall.Transparency = 0.5
                wall.Color = COLORS.IceBlue
                wall.Material = Enum.Material.Ice
                wall.CastShadow = false
                wall.Position = frozenPos + wallData.offset
                wall.Parent = workspace
                table.insert(iceBlockCache[targetPlayer], wall)
            end
            
            -- Billboard
            local billboard = Instance.new("BillboardGui")
            billboard.Name = "IceName_" .. targetPlayer.Name
            billboard.Adornee = iceContainer
            billboard.Size = UDim2.new(0, 150, 0, 50)
            billboard.StudsOffset = Vector3.new(0, 5.5, 0)
            billboard.AlwaysOnTop = true
            billboard.Parent = iceContainer
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = "FROZEN: " .. targetPlayer.Name
            nameLabel.TextColor3 = COLORS.IceBlue
            nameLabel.Font = Enum.Font.GothamBold
            nameLabel.TextSize = 14
            nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 50, 80)
            nameLabel.TextStrokeTransparency = 0.3
            nameLabel.Parent = billboard
            
            local statusLabel = Instance.new("TextLabel")
            statusLabel.Size = UDim2.new(1, 0, 0.5, 0)
            statusLabel.Position = UDim2.new(0, 0, 0.5, 0)
            statusLabel.BackgroundTransparency = 1
            statusLabel.Text = "FROZEN"
            statusLabel.TextColor3 = COLORS.Text
            statusLabel.Font = Enum.Font.GothamBold
            statusLabel.TextSize = 12
            statusLabel.TextStrokeColor3 = Color3.fromRGB(0, 50, 80)
            statusLabel.TextStrokeTransparency = 0.3
            statusLabel.Parent = billboard
            table.insert(iceBlockCache[targetPlayer], billboard)
            
            -- Frozen Clone (Visual)
            local fakeChar = Instance.new("Model")
            fakeChar.Name = "FrozenClone_" .. targetPlayer.Name
            fakeChar.Parent = workspace
            table.insert(iceBlockCache[targetPlayer], fakeChar)
            
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    pcall(function()
                        local clone = part:Clone()
                        clone.Anchored = true
                        clone.CanCollide = false
                        clone.Transparency = math.max(part.Transparency, 0.3)
                        local offset = hrp.CFrame:ToObjectSpace(part.CFrame)
                        clone.CFrame = CFrame.new(frozenPos) * offset
                        if clone:IsA("MeshPart") or clone:IsA("Part") then
                            clone.Color = Color3.fromRGB(
                                math.min(255, math.floor(clone.Color.R * 255 * 0.5 + 100)),
                                math.min(255, math.floor(clone.Color.G * 255 * 0.5 + 150)),
                                math.min(255, math.floor(clone.Color.B * 255 * 0.5 + 200))
                            )
                            clone.Material = Enum.Material.Ice
                        end
                        clone.Parent = fakeChar
                    end)
                end
            end
            
            -- Highlight on Clone
            local highlight = Instance.new("Highlight")
            highlight.FillColor = COLORS.IceBlue
            highlight.OutlineColor = Color3.fromRGB(200, 240, 255)
            highlight.FillTransparency = 0.6
            highlight.OutlineTransparency = 0
            highlight.Parent = fakeChar
            table.insert(iceBlockCache[targetPlayer], highlight)
            
            -- Update Loop
            iceUpdateConnections[targetPlayer] = run.Heartbeat:Connect(function()
                pcall(function()
                    if not CONFIG.IceBlockEnabled then clearIceBlock(targetPlayer) return end
                    local currentChar = targetPlayer.Character
                    if not currentChar then return end
                    local currentHRP = currentChar:FindFirstChild("HumanoidRootPart")
                    if not currentHRP then return end
                    local distance = (currentHRP.Position - frozenPos).Magnitude
                    if distance > 10 then
                        statusLabel.Text = "ESCAPED! (" .. math.floor(distance) .. " studs)"
                        statusLabel.TextColor3 = COLORS.Red
                    else
                        statusLabel.Text = "FROZEN"
                        statusLabel.TextColor3 = COLORS.Text
                    end
                end)
            end)
        end)
    end)
end

local function updateAllIceBlocks()
    for player, _ in pairs(iceBlockCache) do clearIceBlock(player) end
    if CONFIG.IceBlockEnabled then
        for _, player in pairs(game.Players:GetPlayers()) do
            if player ~= plr and player.Character then createIceBlock(player) end
        end
    end
end

