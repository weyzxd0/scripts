-- ===== SPIDER MODE =====
connections.spiderMode = run.Heartbeat:Connect(function()
    if not CONFIG.SpiderMode then
        if spiderBodyVel then spiderBodyVel:Destroy() spiderBodyVel = nil end
        if spiderBodyGyro then spiderBodyGyro:Destroy() spiderBodyGyro = nil end
        return
    end
    local char = plr.Character
    if not char then return end
    local hrp, hum = char:FindFirstChild("HumanoidRootPart"), char:FindFirstChildWhichIsA("Humanoid")
    if not hrp or not hum then return end
    local moveDirection = hum.MoveDirection
    if moveDirection.Magnitude > 0 then
        local ray = Ray.new(hrp.Position, moveDirection * 4)
        local hit, position, normal = workspace:FindPartOnRay(ray, char)
        if hit and hit:IsA("BasePart") then
            if not spiderBodyVel then
                spiderBodyVel = Instance.new("BodyVelocity", hrp)
                spiderBodyVel.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            end
            if not spiderBodyGyro then
                spiderBodyGyro = Instance.new("BodyGyro", hrp)
                spiderBodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
                spiderBodyGyro.P = 9e4
            end
            spiderBodyVel.Velocity = Vector3.new(0, 30, 0)
            spiderBodyGyro.CFrame = hrp.CFrame
        else
            if spiderBodyVel then spiderBodyVel:Destroy() spiderBodyVel = nil end
            if spiderBodyGyro then spiderBodyGyro:Destroy() spiderBodyGyro = nil end
        end
    else
        if spiderBodyVel then spiderBodyVel:Destroy() spiderBodyVel = nil end
        if spiderBodyGyro then spiderBodyGyro:Destroy() spiderBodyGyro = nil end
    end
end)

