-- Controllable Fly Functions
local function stopControlFly()
    isControlFlying = false
    pcall(function()
        local hum = plr.Character and plr.Character:FindFirstChildWhichIsA("Humanoid")
        if hum then hum.PlatformStand = false end
    end)
    if controlFlyBodyGyro then pcall(function() controlFlyBodyGyro:Destroy() end) controlFlyBodyGyro = nil end
    if controlFlyBodyVel then pcall(function() controlFlyBodyVel:Destroy() end) controlFlyBodyVel = nil end
    if controlFlyConnection then pcall(function() controlFlyConnection:Disconnect() end) controlFlyConnection = nil end
    if controlFlyTimerConnection then pcall(function() controlFlyTimerConnection:Disconnect() end) controlFlyTimerConnection = nil end
    cfBtn.Text = "START FLY"
    cfStatus.Text = "Ready"
    cfStatus.TextColor3 = COLORS.Primary
end

local function startControlFly()
    local char = plr.Character
    if not char then notify("Error", "No character!", 2) return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if not hrp then notify("Error", "No HumanoidRootPart!", 2) return end
    
    stopControlFly()
    isControlFlying = true
    cfBtn.Text = "STOP FLY"
    cfStatus.Text = "Lifting..."
    cfStatus.TextColor3 = COLORS.Accent
    
    if hum then hum.PlatformStand = true end
    
    controlFlyBodyGyro = Instance.new("BodyGyro")
    controlFlyBodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    controlFlyBodyGyro.P = 1e4
    controlFlyBodyGyro.D = 500
    controlFlyBodyGyro.Parent = hrp
    
    controlFlyBodyVel = Instance.new("BodyVelocity")
    controlFlyBodyVel.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    controlFlyBodyVel.Velocity = Vector3.new(0, 0, 0)
    controlFlyBodyVel.Parent = hrp
    
    local startTime = tick()
    local duration = 15
    local liftPhase = true
    local targetHeight = hrp.Position.Y + 5
    local flyAngle = 0
    
    controlFlyConnection = run.Heartbeat:Connect(function()
        pcall(function()
            if not isControlFlying or not hrp or not hrp.Parent then stopControlFly() return end
            if liftPhase then
                if hrp.Position.Y < targetHeight then
                    controlFlyBodyVel.Velocity = Vector3.new(0, 30, 0)
                    controlFlyBodyGyro.CFrame = hrp.CFrame
                else
                    liftPhase = false
                    local camLook = workspace.CurrentCamera.CFrame.LookVector
                    flyAngle = math.atan2(-camLook.X, -camLook.Z)
                    cfStatus.Text = "Flying! A/D to turn"
                    cfStatus.TextColor3 = COLORS.Success
                    notify("Hulk Fly", "Flying forward! A/D to turn!", 2)
                end
                return
            end
            local currentSpeed = CONFIG.ControlFlySpeed * 50
            if uis:IsKeyDown(Enum.KeyCode.A) then flyAngle = flyAngle - 0.03 end
            if uis:IsKeyDown(Enum.KeyCode.D) then flyAngle = flyAngle + 0.03 end
            if uis:IsKeyDown(Enum.KeyCode.W) then currentSpeed = CONFIG.ControlFlySpeed * 50 * 1.5 end
            if uis:IsKeyDown(Enum.KeyCode.S) then currentSpeed = CONFIG.ControlFlySpeed * 50 * 0.5 end
            local forwardDir = Vector3.new(-math.sin(flyAngle), 0, -math.cos(flyAngle))
            controlFlyBodyVel.Velocity = forwardDir * currentSpeed
            local targetPos = hrp.Position + forwardDir
            local lookCF = CFrame.new(hrp.Position, targetPos)
            controlFlyBodyGyro.CFrame = lookCF * CFrame.Angles(math.rad(90), 0, 0)
        end)
    end)
    
    controlFlyTimerConnection = run.Heartbeat:Connect(function()
        if not isControlFlying then return end
        local elapsed = tick() - startTime
        local remaining = math.max(0, duration - elapsed)
        if not liftPhase then
            cfStatus.Text = string.format("%.1fs | Spd: %.1f", remaining, CONFIG.ControlFlySpeed)
        end
        if remaining <= 0 then
            notify("Hulk Fly", "Time expired!", 2)
            stopControlFly()
        end
    end)
    notify("Hulk Fly", "Flight starting!", 2)
end

cfBtn.MouseButton1Click:Connect(function()
    if isControlFlying then stopControlFly() else startControlFly() end
end)

